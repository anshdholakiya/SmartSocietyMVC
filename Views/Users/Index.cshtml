@{
    ViewData["Title"] = "Manage Residents";
    var currentUserRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "resident";
    var currentUserId = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    
    // Only admins should really be seeing this page with action buttons, but we'll render defensively
    var users = ViewBag.Users as List<SmartSocietyMVC.Models.User> ?? new List<SmartSocietyMVC.Models.User>();
}

<div class="space-y-6 animate-fade-in">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="user" class="text-blue-600 w-6 h-6"></i> Resident Directory
        </h2>
        
        <!-- Search form could be added here if needed, omitted for brevity as it requires JS/Controller logic -->
    </div>

    @if (TempData["UserSuccess"] != null)
    {
        <div class="p-3 rounded-lg text-sm font-medium bg-green-50 text-green-700">
            @TempData["UserSuccess"]
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-500 text-xs uppercase font-bold border-b border-slate-100">
                <tr>
                    <th class="p-4">Resident Profile</th>
                    <th class="p-4">Account Status</th>
                    <th class="p-4">Location</th>
                    <th class="p-4">Role</th>
                    @if (currentUserRole == "admin")
                    {
                        <th class="p-4 text-right">Actions</th>
                    }
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (users.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center p-12">
                            <i data-lucide="users" class="mx-auto text-slate-200 mb-4 w-12 h-12"></i>
                            <p class="text-slate-400 font-medium">No residents found.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var u in users)
                    {
                        <tr class="hover:bg-slate-50 transition duration-150">
                            <!-- 1. RESIDENT INFO + JOIN DATE -->
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(u.ProfilePicture))
                                    {
                                        <img src="@u.ProfilePicture" alt="@u.Name" class="w-10 h-10 rounded-full object-cover shadow-sm border border-slate-200" />
                                    }
                                    else
                                    {
                                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-sm @(u.Role == "admin" ? "bg-purple-600" : "bg-blue-500")">
                                            @(string.IsNullOrEmpty(u.Name) ? "U" : u.Name.Substring(0, 1).ToUpper())
                                        </div>
                                    }
                                    <div>
                                        <p class="font-bold text-slate-800">@u.Name</p>
                                        <p class="text-xs text-slate-400 font-medium">@u.Email</p>
                                        <div class="flex items-center gap-1 mt-1 text-[10px] text-slate-400">
                                            <i data-lucide="calendar" class="w-3 h-3"></i> Joined: @u.CreatedAt.ToShortDateString()
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <!-- 2. ACCOUNT STATUS -->
                            <td class="p-4">
                                @if (u.IsSetup)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200">
                                        <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Verified
                                    </span>
                                }
                                else
                                {
                                    <div class="flex flex-col items-start gap-1">
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-amber-100 text-amber-700 border border-amber-200">
                                            <i data-lucide="clock" class="w-3.5 h-3.5"></i> Pending
                                        </span>
                                        <span class="text-[10px] text-slate-400 pl-1">Invited via Link</span>
                                    </div>
                                }
                            </td>

                            <!-- 3. LOCATION -->
                            <td class="p-4">
                                @if (!string.IsNullOrEmpty(u.Wing) && !string.IsNullOrEmpty(u.FlatNumber))
                                {
                                    <span class="flex items-center gap-1.5 text-sm font-bold text-slate-700 bg-slate-100 px-3 py-1.5 rounded-lg w-fit border border-slate-200">
                                        <i data-lucide="map-pin" class="text-slate-400 w-3.5 h-3.5"></i> @u.Wing - @u.FlatNumber
                                    </span>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 italic">Not Assigned</span>
                                }
                            </td>

                            <!-- 4. ROLE -->
                            <td class="p-4">
                                <span class="text-xs font-bold px-2 py-1 rounded border flex items-center gap-1 w-fit uppercase tracking-wider @(u.Role == "admin" ? "bg-purple-50 text-purple-700 border-purple-200" : "bg-slate-50 text-slate-600 border-slate-200")">
                                    <i data-lucide="@(u.Role == "admin" ? "shield" : "user")" class="w-3 h-3"></i> @u.Role
                                </span>
                            </td>

                            <!-- 5. ACTIONS -->
                            @if (currentUserRole == "admin")
                            {
                                <td class="p-4 text-right">
                                    @if (u.Id.ToString() != currentUserId)
                                    {
                                        <div class="flex justify-end gap-2">
                                            <form asp-controller="Users" asp-action="ToggleRole" asp-route-id="@u.Id" method="post" onsubmit="return confirm('Change role for this user?');">
                                                <button type="submit" class="text-xs bg-white border border-slate-200 hover:bg-slate-50 text-slate-600 px-3 py-1.5 rounded-lg font-bold transition shadow-sm">
                                                    @(u.Role == "admin" ? "Demote" : "Promote")
                                                </button>
                                            </form>

                                            <form asp-controller="Users" asp-action="Delete" asp-route-id="@u.Id" method="post" onsubmit="return confirm('Are you sure? This will remove the user permanently.');">
                                                <button type="submit" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Remove User">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
