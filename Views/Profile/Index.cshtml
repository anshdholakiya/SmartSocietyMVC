@model SmartSocietyMVC.Models.User
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActiveTab"] = "profile";
}

<div class="max-w-2xl mx-auto space-y-6 animate-fade-in pb-24">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded">@TempData["SuccessMessage"]</div>
    }

    <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
        <i data-lucide="user" class="text-blue-600"></i> My Profile
    </h2>

    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
        <!-- Avatar -->
        <form asp-controller="Profile" asp-action="Update" method="post" enctype="multipart/form-data" class="space-y-6">
            <div class="flex items-center gap-6 mb-4">
                <div class="relative group">
                    <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center text-slate-400 overflow-hidden shadow-sm border-2 border-slate-200">
                        @if (!string.IsNullOrEmpty(Model?.ProfilePicture))
                        {
                            <img src="@Model.ProfilePicture" class="w-full h-full object-cover" alt="Profile" />
                        }
                        else
                        {
                            <i data-lucide="user" class="w-10 h-10"></i>
                        }
                    </div>
                    <label class="absolute inset-0 bg-black/40 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 cursor-pointer transition-opacity z-10">
                        <i data-lucide="camera" class="w-6 h-6"></i>
                        <input type="file" name="profilePicture" class="hidden" accept="image/png, image/jpeg" />
                    </label>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-slate-800">@Model?.Name</h3>
                    <span class="px-2 py-1 rounded text-xs font-bold bg-blue-50 text-blue-600 border border-blue-100 uppercase tracking-wider mt-1 inline-block">
                        @Model?.Role
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Full Name</label>
                    <div class="relative">
                        <i data-lucide="user" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="name" type="text" value="@Model?.Name"
                            class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Email Address</label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input type="email" value="@Model?.Email"
                            class="w-full pl-10 p-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-500 cursor-not-allowed"
                            disabled />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Wing</label>
                    <div class="relative">
                        <i data-lucide="map-pin" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="wing" type="text" value="@Model?.Wing" placeholder="e.g. A"
                            class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Flat Number</label>
                    <div class="relative">
                        <i data-lucide="home" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="flatNumber" type="text" value="@Model?.FlatNumber" placeholder="e.g. 101"
                            class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Profession</label>
                    <div class="relative">
                        <i data-lucide="briefcase" class="absolute left-3 top-3 text-slate-400 w-[18px] h-[18px]"></i>
                        <input name="profession" type="text" value="@Model?.Profession" placeholder="e.g. Software Engineer"
                            class="w-full pl-10 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-100 flex justify-end">
                <button type="submit" class="bg-slate-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-800 transition flex items-center gap-2">
                    <i data-lucide="save" class="w-[18px] h-[18px]"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
