@model IEnumerable<SmartSocietyMVC.Models.Booking>
@{
    ViewData["Title"] = "Booking Requests";
    Layout = "_DashboardLayout";
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div>
        <h1 class="text-3xl font-bold text-slate-800">Booking Requests</h1>
        <p class="text-slate-500">Approve or reject resident facility bookings.</p>
    </div>

    <div class="space-y-4">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center p-10 text-slate-500 bg-white rounded-2xl">
                No booking requests found.
            </div>
        }
        else
        {
            foreach (var b in Model)
            {
                <div class="bg-white border border-slate-100 p-5 rounded-2xl flex flex-col md:flex-row items-center justify-between shadow-sm gap-4">
                    <div class="flex items-center gap-4 w-full md:w-auto">
                        <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center flex-shrink-0">
                            <i data-lucide="calendar" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-800">@b.Facility?.Name</h3>
                            <p class="text-sm text-slate-500">
                                @b.Date.ToString("ddd MMM dd yyyy") • <span class="font-semibold">@b.User?.Name</span> (@b.User?.Wing-@b.User?.FlatNumber)
                            </p>
                            <p class="text-xs text-slate-600 font-medium mt-1">
                                @b.Days Days • Total: ₹@b.TotalPrice
                            </p>
                            <p class="text-xs text-slate-400">"@b.Purpose"</p>
                        </div>
                    </div>

                    <div class="flex gap-2 w-full md:w-auto justify-end">
                        @if (b.Status == "pending")
                        {
                            <form asp-action="UpdateBookingStatus" asp-controller="Dashboard" method="post" m-0>
                                <input type="hidden" name="id" value="@b.Id" />
                                <input type="hidden" name="status" value="approved" />
                                <button type="submit" class="px-4 py-2 bg-green-100 text-green-700 rounded-lg text-sm font-bold hover:bg-green-200 transition">Approve</button>
                            </form>
                            <form asp-action="UpdateBookingStatus" asp-controller="Dashboard" method="post" m-0>
                                <input type="hidden" name="id" value="@b.Id" />
                                <input type="hidden" name="status" value="rejected" />
                                <button type="submit" class="px-4 py-2 bg-red-100 text-red-700 rounded-lg text-sm font-bold hover:bg-red-200 transition">Reject</button>
                            </form>
                        }
                        else
                        {
                            <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-2 @(b.Status == "approved" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                <i data-lucide="@(b.Status == "approved" ? "check-circle" : "x-circle")" class="w-[14px] h-[14px]"></i> @b.Status
                            </span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
