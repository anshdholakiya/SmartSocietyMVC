@model IEnumerable<SmartSocietyMVC.Models.Facility>
@{
    ViewData["Title"] = "Manage Facilities";
    Layout = "_DashboardLayout";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "admin";
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Manage Facilities</h1>
            <p class="text-slate-500">Add, update, or remove community facilities.</p>
        </div>
        @if (userRole == "admin")
        {
            <button onclick="openFacilityModal()" class="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                <i data-lucide="plus" class="w-[18px] h-[18px]"></i> Add Facility
            </button>
        }
    </div>

    <!-- Modal/Form -->
    @if (userRole == "admin")
    {
        <div id="facilityModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-2xl w-full max-w-lg p-6 relative shadow-2xl animate-scale-in">
                <button onclick="closeFacilityModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
                <h2 id="modalTitle" class="text-xl font-bold text-slate-800 mb-6">
                    Add New Facility
                </h2>

                <form id="facilityForm" method="post" action="/Dashboard/SaveFacility" class="space-y-4">
                    <input type="hidden" id="facilityId" name="Id" value="" />
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Facility Name</label>
                        <input id="facilityName" name="Name" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Community Hall" required />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1">Price Per Day (₹)</label>
                            <input id="facilityPrice" type="number" name="PricePerDay" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1">Capacity</label>
                            <input id="facilityCapacity" type="number" name="Capacity" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Persons" required />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Description</label>
                        <textarea id="facilityDescription" name="Description" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Details about the facility..." rows="3"></textarea>
                    </div>

                    <button id="submitButton" type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700 transition">
                        Create Facility
                    </button>
                </form>
            </div>
        </div>
    }

    <!-- List -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (Model == null || !Model.Any())
        {
            <p class="text-center text-slate-400 py-10 col-span-full">No facilities found.</p>
        }
        else
        {
            @foreach (var f in Model)
            {
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="font-bold text-lg text-slate-800">@f.Name</h3>
                        
                        @if (userRole == "admin")
                        {
                            <div class="flex gap-2">
                                <button onclick="openFacilityModal(@f.Id, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(f.Name))', @f.PricePerDay, @f.Capacity, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(f.Description ?? ""))')" class="text-blue-600 hover:bg-blue-50 p-2 rounded-lg">
                                    <i data-lucide="edit-2" class="w-[18px] h-[18px]"></i>
                                </button>
                                <form asp-action="DeleteFacility" asp-controller="Dashboard" method="post" m-0 onsubmit="return confirm('Are you sure you want to delete this facility?');">
                                    <input type="hidden" name="id" value="@f.Id" />
                                    <button type="submit" class="text-red-500 hover:bg-red-50 p-2 rounded-lg">
                                        <i data-lucide="trash-2" class="w-[18px] h-[18px]"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                    <p class="text-sm text-slate-500 mb-4 line-clamp-2">@(string.IsNullOrEmpty(f.Description) ? "No description provided." : f.Description)</p>
                    <div class="flex justify-between items-center text-sm font-medium text-slate-700">
                        <span>Capacity: @f.Capacity</span>
                        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full">₹@f.PricePerDay/day</span>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function openFacilityModal(id = '', name = '', price = '', capacity = '', description = '') {
            document.getElementById('facilityModal').classList.remove('hidden');
            
            document.getElementById('facilityId').value = id;
            document.getElementById('facilityName').value = name;
            document.getElementById('facilityPrice').value = price;
            document.getElementById('facilityCapacity').value = capacity;
            document.getElementById('facilityDescription').value = description;

            if (id) {
                document.getElementById('modalTitle').innerText = 'Edit Facility';
                document.getElementById('submitButton').innerText = 'Update Facility';
            } else {
                document.getElementById('modalTitle').innerText = 'Add New Facility';
                document.getElementById('submitButton').innerText = 'Create Facility';
            }
        }

        function closeFacilityModal() {
            document.getElementById('facilityModal').classList.add('hidden');
        }
    </script>
}
