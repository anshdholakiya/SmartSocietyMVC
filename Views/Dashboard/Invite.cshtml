@{
    ViewData["Title"] = "Invite New Resident";
    Layout = "_DashboardLayout";
}

<div class="max-w-2xl mx-auto animate-fade-in">
    <h2 class="text-2xl font-bold text-slate-800 mb-6">Invite New Resident</h2>
    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 rounded-xl text-sm font-bold flex items-center gap-2 bg-green-50 text-green-700">
                <i data-lucide="check-circle" class="w-5 h-5"></i>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 p-4 rounded-xl text-sm font-bold flex items-center gap-2 bg-red-50 text-red-700">
                <i data-lucide="alert-circle" class="w-5 h-5"></i>
                @TempData["ErrorMessage"]
            </div>
        }

        <form method="post" action="/Dashboard/Invite" class="space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Resident Name</label>
                    <input type="text" name="name" placeholder="e.g. Rahul Sharma" required
                           class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>

                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Email Address</label>
                    <input type="email" name="email" placeholder="e.g. rahul@example.com" required
                           class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Wing</label>
                    <input type="text" name="wing" placeholder="e.g. A" 
                           class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Flat No.</label>
                    <input type="text" name="flatNumber" placeholder="e.g. 101" 
                           class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>
            </div>
            
            <input type="hidden" name="role" value="resident" />

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl font-bold text-lg shadow-lg shadow-blue-200 transition-all active:scale-95 flex items-center justify-center gap-2">
                <i data-lucide="user-plus" class="w-5 h-5"></i> Send Invitation
            </button>
        </form>
    </div>
</div>
