@{
    ViewData["Title"] = "Billing & Finances";
    Layout = "_DashboardLayout";
    
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "admin";
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in">
    <h2 class="text-2xl font-bold text-slate-800">Billing & Finances</h2>

    @if (userRole == "admin")
    {
        @await Html.PartialAsync("_AdminBills")
    }
    else
    {
        @await Html.PartialAsync("_ResidentBills")
    }
</div>
