@model IEnumerable<SmartSocietyMVC.Models.Complaint>
@{
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "resident";
}

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
    <h3 class="text-xl font-bold mb-6 flex items-center gap-2 text-slate-800">
        <i data-lucide="message-square" class="text-blue-500 w-6 h-6"></i> Recent Complaints
    </h3>
    
    <div class="space-y-6">
        @if (Model == null || !Model.Any())
        {
            <p class="text-slate-400 text-center">No complaints found.</p>
        }
        else
        {
            foreach (var c in Model)
            {
                <div class="border-b border-slate-100 pb-6 last:border-0 relative">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h4 class="font-bold text-slate-800 text-lg">@c.Title</h4>
                            <div class="flex items-center gap-2 text-xs text-slate-400 mt-1">
                                <i data-lucide="clock" class="w-3 h-3"></i> @c.CreatedAt.ToString("M/d/yyyy")
                                
                                @if (userRole == "admin" && c.User != null)
                                {
                                    <span class="flex items-center gap-1 ml-2 bg-slate-50 px-2 py-0.5 rounded">
                                        <i data-lucide="user" class="w-3 h-3"></i> @c.User.Name (@c.User.Wing-@c.User.FlatNumber)
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- STATUS BADGE -->
                        <div class="flex flex-col items-end gap-2">
                            @{
                                string badgeColor = "bg-slate-100 text-slate-600 border-slate-200";
                                string iconName = "clock";
                                if (c.Status == "resolved") { badgeColor = "bg-green-100 text-green-700 border-green-200"; iconName = "check-circle"; }
                                else if (c.Status == "in-progress") { badgeColor = "bg-yellow-100 text-yellow-700 border-yellow-200"; iconName = "construction"; }
                            }
                            <span class="px-3 py-1 rounded-full text-xs font-bold border flex items-center gap-1 uppercase tracking-wider @badgeColor">
                                <i data-lucide="@iconName" class="w-3 h-3"></i>
                                @c.Status
                            </span>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row gap-4">
                        @if (!string.IsNullOrEmpty(c.ImageUrl))
                        {
                            <img src="@c.ImageUrl" alt="Proof" class="w-24 h-24 object-cover rounded-xl border border-slate-200" />
                        }
                        
                        <div class="flex-1">
                            <p class="text-slate-600 text-sm italic bg-slate-50 p-3 rounded-lg border border-slate-100">
                                "@c.Description"
                            </p>
                        </div>
                    </div>

                    <!-- ADMIN CONTROLS -->
                    @if (userRole == "admin")
                    {
                        <div class="mt-4 pt-4 border-t border-slate-50 flex justify-end items-center gap-3">
                            <form asp-action="UpdateComplaintStatus" asp-controller="Dashboard" method="post" class="flex items-center m-0">
                                <input type="hidden" name="id" value="@c.Id" />
                                <select name="status" onchange="this.form.submit()" class="text-xs font-bold text-slate-600 bg-white border border-slate-300 rounded-lg px-3 py-2 outline-none focus:border-blue-500 cursor-pointer hover:bg-slate-50 transition">
                                    <option value="pending" selected="@(c.Status == "pending")">Pending</option>
                                    <option value="in-progress" selected="@(c.Status == "in-progress")">In Progress</option>
                                    <option value="resolved" selected="@(c.Status == "resolved")">Resolved</option>
                                </select>
                            </form>

                            <form asp-action="DeleteComplaint" asp-controller="Dashboard" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to delete this complaint?');">
                                <input type="hidden" name="id" value="@c.Id" />
                                <button type="submit" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Delete Complaint">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
