@{
    ViewData["Title"] = "Event Booking";
    Layout = "_DashboardLayout";
    var facilities = ViewBag.Facilities as IEnumerable<dynamic> ?? new List<dynamic>();
    var myBookings = ViewBag.MyBookings as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="p-6 md:p-10 space-y-8 animate-fade-in pb-24">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-slate-800">Event Booking</h1>
            <p class="text-slate-500">Reserve community halls and facilities.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Booking Form -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100 h-fit">
            <h2 class="text-xl font-bold text-slate-800 mb-6">New Booking</h2>
            <form method="post" action="/Dashboard/BookEvent" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Select Facility</label>
                    <select name="facilityId" id="facilitySelect" onchange="calculatePrice()" class="w-full p-3 bg-slate-50 border rounded-xl" required>
                        <option value="" data-price="0">-- Choose --</option>
                        @foreach (var f in facilities)
                        {
                            <option value="@f.Id" data-price="@f.PricePerDay">@f.Name - ₹@f.PricePerDay/day</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Date</label>
                    <input type="date" name="date" class="w-full p-3 bg-slate-50 border rounded-xl" required />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-500 mb-1">No. of Days</label>
                        <input type="number" name="days" id="daysInput" oninput="calculatePrice()" min="1" value="1" class="w-full p-3 bg-slate-50 border rounded-xl" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-500 mb-1">Est. Price</label>
                        <div id="estPriceDisplay" class="w-full p-3 bg-slate-100 border rounded-xl text-slate-700 font-bold">
                            ₹0.00
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-500 mb-1">Purpose/Event Name</label>
                    <input type="text" name="purpose" class="w-full p-3 bg-slate-50 border rounded-xl" placeholder="Birthday Party, Meeting..." required />
                </div>

                <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition">
                    Request Booking
                </button>
            </form>
        </div>

        <!-- My Bookings List -->
        <div class="lg:col-span-2">
            <h2 class="text-xl font-bold text-slate-800 mb-4">My Bookings</h2>
            @if (!myBookings.Any())
            {
                <div class="bg-slate-50 rounded-xl p-8 text-center text-slate-500">
                    No bookings found.
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var b in myBookings)
                    {
                        <div class="bg-white border border-slate-100 p-5 rounded-2xl flex items-center justify-between shadow-sm">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                                    <i data-lucide="calendar" class="w-5 h-5"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-slate-800">@b.Facility?.Name</h3>
                                    <p class="text-sm text-slate-500">@b.Date.ToString("ddd MMM dd yyyy") • @b.Purpose</p>
                                </div>
                            </div>

                            <span class="px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider flex items-center gap-2 @(b.Status == "approved" ? "bg-green-100 text-green-700" : b.Status == "rejected" ? "bg-red-100 text-red-700" : "bg-yellow-100 text-yellow-700")">
                                <i data-lucide="@(b.Status == "approved" ? "check-circle" : b.Status == "rejected" ? "x-circle" : "clock")" class="w-[14px] h-[14px]"></i> @b.Status
                            </span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function calculatePrice() {
            var select = document.getElementById('facilitySelect');
            var price = select.options[select.selectedIndex].getAttribute('data-price');
            var days = document.getElementById('daysInput').value;
            var total = (parseFloat(price) || 0) * parseInt((days) || 0);
            document.getElementById('estPriceDisplay').innerText = '₹' + total.toFixed(2);
        }
    </script>
}
