@{
    var bills = ViewBag.MyBills as IEnumerable<dynamic> ?? new List<dynamic>(); // Mock data
}

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
        <h3 class="font-bold text-slate-700">My Payment History</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-slate-50 text-slate-500 text-sm uppercase">
                <tr><th class="p-4">Description</th><th class="p-4">Amount</th><th class="p-4">Status</th></tr>
            </thead>
            <tbody>
                @if (!bills.Any())
                {
                    <tr><td colspan="3" class="p-6 text-center text-slate-400">No bills found.</td></tr>
                }
                @foreach(var b in bills)
                {
                    <tr class="border-b last:border-0 hover:bg-slate-50 transition">
                        <td class="p-4">
                            <span class="block font-bold text-slate-700">@(b.description ?? b.month)</span>
                            <span class="text-xs text-slate-500">@b.month</span>
                        </td>
                        <td class="p-4 font-bold text-slate-700">₹@b.amount</td>
                        <td class="p-4">
                            <span class="px-3 py-1 rounded-full text-xs font-bold @(b.status == "paid" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                @b.status.ToUpper()
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
