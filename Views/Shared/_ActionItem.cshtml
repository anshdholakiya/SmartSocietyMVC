@model dynamic

<div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl border border-slate-100 group hover:bg-white hover:border-blue-200 hover:shadow-sm transition-all cursor-pointer">
    <div class="flex items-center gap-4">
        <div class="w-3 h-3 rounded-full ring-2 ring-white shadow-sm @(Model.Priority == "High" ? "bg-red-500" : Model.Priority == "Medium" ? "bg-amber-500" : "bg-blue-500")"></div>
        <span class="font-semibold text-slate-700">@Model.Title</span>
    </div>
    <span class="text-xs font-bold px-2 py-1 rounded border @(Model.Status == "Overdue" ? "bg-red-50 text-red-600 border-red-100" : "bg-slate-100 text-slate-500 border-slate-200")">
        @Model.Status
    </span>
</div>
