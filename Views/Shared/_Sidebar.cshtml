@using System.Security.Claims
@using SmartSocietyMVC.Data
@inject ApplicationDbContext DbContext

@{
    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "resident";
    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "dashboard";
    var userName = User.Identity?.Name ?? "User";
    
    var userIdString = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
    string profilePic = null;
    if (int.TryParse(userIdString, out int userId))
    {
        var user = DbContext.Users.Find(userId);
        profilePic = user?.ProfilePicture;
    }
}

<aside class="w-full md:w-64 bg-slate-900 text-white md:h-screen flex flex-col relative md:fixed left-0 top-0 shadow-2xl z-50">
    
    <div class="p-6 border-b border-slate-800 flex items-center gap-3">
        <div class="bg-blue-600 p-2 rounded-lg">
            <i data-lucide="shield" class="text-white w-6 h-6"></i>
        </div>
        <div>
            <h1 class="font-bold text-lg tracking-wide">Smart Society</h1>
            <p class="text-xs text-slate-400">Society Manager</p>
        </div>
    </div>

    
    <nav class="flex-1 py-6 px-3 space-y-2 overflow-y-auto max-h-64 md:max-h-full">
        <div class="px-3 mb-2 text-xs font-semibold text-slate-500 uppercase tracking-wider">
            Overview
        </div>

        <a href="@Url.Action("Index", "Dashboard")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "dashboard" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
            <i data-lucide="home" class="w-5 h-5"></i>
            <span class="text-sm font-medium">Dashboard</span>
        </a>

        <a href="@Url.Action("Index", "Notices")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "notices" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
            <i data-lucide="bell" class="w-5 h-5"></i>
            <span class="text-sm font-medium">Notices</span>
        </a>

        <a href="@Url.Action("Index", "Complaints")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "complaints" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
            <i data-lucide="message-square" class="w-5 h-5"></i>
            <span class="text-sm font-medium">Complaints</span>
        </a>

        @if (role == "admin")
        {
            <div class="px-3 mt-6 mb-2 text-xs font-semibold text-slate-500 uppercase tracking-wider">
                Admin Controls
            </div>
            <a href="@Url.Action("Index", "Society")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "society" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="users" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Manage Society</span>
            </a>
            <a href="@Url.Action("Index", "Facilities")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "facilities" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="building" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Facilities</span>
            </a>
            <a href="@Url.Action("Index", "Events")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "events" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="calendar" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Booking Requests</span>
            </a>
            <a href="@Url.Action("Index", "Invite")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "invite" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="user-plus" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Invite Residents</span>
            </a>
            <a href="@Url.Action("Index", "Bills")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "bills" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="receipt" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Billing System</span>
            </a>
            <a href="@Url.Action("Index", "Users")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "residents" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="users" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Directory</span>
            </a>
        }
        else if (role == "resident")
        {
            <div class="px-3 mt-6 mb-2 text-xs font-semibold text-slate-500 uppercase tracking-wider">
                Resident Menu
            </div>
            <a href="@Url.Action("Index", "Society")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "society" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="users" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Society Info</span>
            </a>
            <a href="@Url.Action("Index", "Events")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "events" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="calendar-days" class="w-5 h-5"></i>
                <span class="text-sm font-medium">Events & Bookings</span>
            </a>
            <a href="@Url.Action("Index", "Bills")" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(activeTab == "bills" ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
                <i data-lucide="receipt" class="w-5 h-5"></i>
                <span class="text-sm font-medium">My Bills</span>
            </a>
        }
    </nav>

    
    <div class="p-4 border-t border-slate-800 bg-slate-950">
        <a href="@Url.Action("Index", "Profile")" class="flex items-center gap-3 mb-4 cursor-pointer hover:bg-slate-800 p-2 rounded-lg transition group">
            <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-blue-400 overflow-hidden border border-slate-700 shadow-sm group-hover:border-blue-500 transition-colors">
                @if (!string.IsNullOrEmpty(profilePic))
                {
                    <img src="@profilePic" class="w-full h-full object-cover" alt="Profile" />
                }
                else
                {
                    <i data-lucide="user" class="w-5 h-5"></i>
                }
            </div>
            <div class="overflow-hidden">
                <p class="text-sm font-bold truncate group-hover:text-blue-400 transition-colors">@userName</p>
                <p class="text-xs text-slate-500 truncate capitalize">@role</p>
            </div>
        </a>

        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="w-full flex items-center justify-center gap-2 bg-slate-800 hover:bg-red-600 text-slate-300 hover:text-white py-2 rounded-lg transition-all duration-300 text-sm font-medium">
                <i data-lucide="log-out" class="w-4 h-4"></i> Sign Out
            </button>
        </form>
    </div>
</aside>
