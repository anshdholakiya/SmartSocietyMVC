@using System.Security.Claims
@using SmartSocietyMVC.Data
@inject ApplicationDbContext DbContext

@{
    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "guest";
    var userName = User.Identity?.Name ?? "User";
    
    var userIdString = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
    string profilePic = null;
    if (int.TryParse(userIdString, out int userId))
    {
        var user = DbContext.Users.Find(userId);
        profilePic = user?.ProfilePicture;
    }
}

<header class="bg-white border-b border-slate-200 sticky top-0 z-30 shadow-sm backdrop-blur-md bg-white/90">
    <div class="flex items-center justify-between px-6 py-4">
        <div>
            <!-- Breadcrumbs or page title could go here -->
        </div>

        <div class="flex items-center gap-6">
            <div class="relative">
                <button class="text-slate-400 hover:text-slate-600 transition-colors relative">
                    <i data-lucide="bell" class="w-6 h-6"></i>
                    <!-- Notification Badge -->
                    <span class="absolute top-0 right-0 transform translate-x-1 -translate-y-1 block h-2.5 w-2.5 rounded-full ring-2 ring-white bg-blue-500"></span>
                </button>
            </div>

            <div class="flex items-center gap-3 pl-6 border-l border-slate-200">
                <div class="text-right hidden sm:block">
                    <p class="text-sm font-semibold text-slate-800">@userName</p>
                    <p class="text-xs text-slate-500 capitalize">@role</p>
                </div>
                <a href="/Profile" class="h-10 w-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 overflow-hidden border border-slate-200 shadow-inner hover:ring-2 hover:ring-blue-400 transition">
                    @if (!string.IsNullOrEmpty(profilePic))
                    {
                        <img src="@profilePic" class="w-full h-full object-cover" alt="Profile" />
                    }
                    else
                    {
                        <i data-lucide="user" class="w-5 h-5"></i>
                    }
                </a>
            </div>
        </div>
    </div>
</header>
