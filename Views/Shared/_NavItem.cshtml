@model dynamic

<a href="@Model.Href" 
   class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 @(Model.IsActive ? "bg-blue-600 text-white shadow-lg shadow-blue-900/50" : "text-slate-400 hover:bg-slate-800 hover:text-white")">
    <i data-lucide="@Model.Icon" class="w-5 h-5"></i>
    <span class="text-sm font-medium">@Model.Label</span>
</a>
