@{
    ViewData["Title"] = "Notices";
    var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "resident";
    var notices = ViewBag.Notices as List<SmartSocietyMVC.Models.Notice> ?? new List<SmartSocietyMVC.Models.Notice>();
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="bell" class="text-blue-600 w-6 h-6"></i> Community Notices
        </h2>

        @if (userRole == "admin")
        {
            <button onclick="toggleForm()" id="formToggleBtn" class="bg-slate-900 text-white px-4 py-2 rounded-xl font-bold flex items-center gap-2 hover:bg-slate-800 transition">
                <i data-lucide="plus" class="w-5 h-5" id="formToggleIcon"></i> 
                <span id="formToggleText">New Notice</span>
            </button>
        }
    </div>

    <!-- CREATE FORM (Admin Only) -->
    @if (userRole == "admin")
    {
        <div id="noticeForm" style="display: none;" class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <h3 class="font-bold text-lg mb-4">Post New Announcement</h3>
            <form asp-controller="Notices" asp-action="Create" method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-slate-500 mb-1">Title</label>
                        <input type="text" name="Title" required
                               class="w-full p-3 border rounded-xl"
                               placeholder="e.g. Water Supply Interruption" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-500 mb-1">Type</label>
                        <select name="Type" class="w-full p-3 border rounded-xl bg-white">
                            <option value="alert">🚨 High Alert</option>
                            <option value="maintenance">🛠 Maintenance</option>
                            <option value="event">🎉 Event</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-500 mb-1">Description (Optional)</label>
                    <textarea name="Description" class="w-full p-3 border rounded-xl h-24" placeholder="Provide detailed information..."></textarea>
                </div>
                <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700">
                    Post Notice
                </button>
            </form>
        </div>
    }

    <!-- NOTICE LIST -->
    <div class="grid gap-4">
        @if (notices.Count == 0)
        {
            <p class="text-center text-slate-400 py-10">No notices found.</p>
        }
        else
        {
            foreach (var notice in notices)
            {
                var bgClass = notice.Type == "alert" ? "bg-red-100 text-red-600" :
                              notice.Type == "maintenance" ? "bg-blue-100 text-blue-600" : "bg-amber-100 text-amber-600";
                
                var badgeBgClass = notice.Type == "alert" ? "bg-red-50 text-red-600" :
                                   notice.Type == "maintenance" ? "bg-blue-50 text-blue-600" : "bg-amber-50 text-amber-600";
                
                var iconName = notice.Type == "alert" ? "alert-triangle" :
                               notice.Type == "maintenance" ? "info" : "calendar";

                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition">
                    <div class="flex justify-between items-start">
                        <div class="flex gap-4">
                            <div class="p-3 rounded-xl h-fit @bgClass">
                                <i data-lucide="@iconName" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-bold uppercase px-2 py-0.5 rounded @badgeBgClass">
                                        @notice.Type
                                    </span>
                                    <span class="text-xs text-slate-400">@notice.CreatedAt.ToShortDateString()</span>
                                </div>
                                <h3 class="text-lg font-bold text-slate-800">@notice.Title</h3>
                                <p class="text-slate-600 mt-2 leading-relaxed">@notice.Description</p>
                            </div>
                        </div>

                        @if (userRole == "admin")
                        {
                            <form asp-controller="Notices" asp-action="Delete" asp-route-id="@notice.Id" method="post" onsubmit="return confirm('Are you sure you want to remove this notice?');">
                                <button type="submit" class="text-slate-400 hover:text-red-500 p-2 hover:bg-red-50 rounded-lg transition" title="Delete Notice">
                                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleForm() {
            const form = document.getElementById('noticeForm');
            const btnText = document.getElementById('formToggleText');
            const btnIcon = document.getElementById('formToggleIcon');
            
            if (form.style.display === 'none') {
                form.style.display = 'block';
                btnText.innerText = 'Cancel';
                btnIcon.setAttribute('data-lucide', 'x');
            } else {
                form.style.display = 'none';
                btnText.innerText = 'New Notice';
                btnIcon.setAttribute('data-lucide', 'plus');
            }
            lucide.createIcons(); // Re-render the new icon
        }
    </script>
}
