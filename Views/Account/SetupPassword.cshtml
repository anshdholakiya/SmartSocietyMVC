@{
    ViewData["Title"] = "Setup Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartSocietyMVC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="selection:bg-blue-100 selection:text-blue-900 bg-slate-900">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="max-w-md w-full bg-white rounded-2xl p-8 shadow-2xl animate-fade-in">
            <div class="text-center mb-8">
                <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="lock" class="text-blue-600 w-[30px] h-[30px]"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-800">Setup Your Account</h2>
                <p class="text-slate-500 text-sm mt-2">Choose a secure password to activate your profile.</p>
            </div>

            <form method="post" action="/Account/SetupPassword" class="space-y-5">
                <input type="hidden" name="email" value="@ViewBag.Email" />
                @if (ViewBag.Success != null)
                {
                    <div class="bg-green-50 border-l-4 border-green-500 p-3 text-green-700 text-sm mb-4">
                        <p class="font-bold">Success</p>
                        <p>@ViewBag.Success</p>
                    </div>
                    <a href="/Account/Login" class="block text-center w-full bg-slate-900 text-white py-3 rounded-lg font-bold">Go to Login</a>
                }
                else
                {
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">New Password</label>
                        <input type="password" name="password" placeholder="••••••••" required minlength="6"
                               class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Confirm Password</label>
                        <input type="password" name="confirmPassword" placeholder="••••••••" required minlength="6"
                               class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                    </div>

                    <button type="submit"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl font-bold shadow-lg shadow-blue-200 transition-all active:scale-95 flex items-center justify-center gap-2">
                        <i data-lucide="check-circle" class="w-5 h-5"></i> Activate Account
                    </button>
                    
                    <script>
                        document.querySelector('form').addEventListener('submit', function(e) {
                            var pwd = document.querySelector('input[name="password"]').value;
                            var conf = document.querySelector('input[name="confirmPassword"]').value;
                            if (pwd !== conf) {
                                e.preventDefault();
                                alert("Passwords do not match!");
                            }
                        });
                    </script>
                }
            </form>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>
