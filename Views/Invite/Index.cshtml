@{
    ViewData["Title"] = "Invite Residents";
}

<div class="p-6 md:p-10 max-w-2xl mx-auto animate-fade-in pb-24">
    <h2 class="text-2xl font-bold text-slate-800 mb-6">Invite New Resident</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
        <form asp-controller="Invite" asp-action="SendInvite" method="post" class="space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Resident Name</label>
                    <input type="text" name="residentName" placeholder="e.g. Rahul Sharma" class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" required />
                </div>

                <div class="col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-2">Email Address</label>
                    <input type="email" name="emailAddress" placeholder="e.g. rahul@example.com" class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Wing</label>
                    <input type="text" name="wing" placeholder="e.g. A" class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Flat No.</label>
                    <input type="text" name="flatNo" placeholder="e.g. 101" class="w-full p-3 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl font-bold text-lg shadow-lg shadow-blue-200 transition-all active:scale-95 flex items-center justify-center gap-2">
                <i data-lucide="user-plus" class="w-5 h-5"></i> Send Invitation
            </button>
        </form>
    </div>
</div>
